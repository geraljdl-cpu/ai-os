#!/usr/bin/env python3
import argparse
import json
from bin import backlog_pg

def queue_add(args):
    t = backlog_pg.add_task(args.title, args.goal, priority=args.priority, task_type=args.task_type)
    print(json.dumps(t, ensure_ascii=False))

def queue_list(_args):
    tasks = backlog_pg.list_tasks()
    out = [{"id": t["id"], "status": t["status"], "priority": t.get("priority"), "title": t.get("title")} for t in tasks[:200]]
    print(json.dumps(out, ensure_ascii=False, indent=2))

def status(_args):
    tasks = backlog_pg.list_tasks()
    counts = {}
    for t in tasks:
        counts[t["status"]] = counts.get(t["status"], 0) + 1
    print(json.dumps({"counts": counts, "total": len(tasks)}, ensure_ascii=False, indent=2))

def main():
    p = argparse.ArgumentParser(prog="aiosctl")
    sub = p.add_subparsers(dest="cmd", required=True)

    q = sub.add_parser("queue", help="queue operations (Postgres)")
    qsub = q.add_subparsers(dest="qcmd", required=True)

    qadd = qsub.add_parser("add", help="add a task")
    qadd.add_argument("title")
    qadd.add_argument("goal")
    qadd.add_argument("--priority", type=int, default=5)
    qadd.add_argument("--task-type", default="DEV_TASK")
    qadd.set_defaults(fn=queue_add)

    qlist = qsub.add_parser("list", help="list tasks")
    qlist.set_defaults(fn=queue_list)

    st = sub.add_parser("status", help="show task counts")
    st.set_defaults(fn=status)

    args = p.parse_args()
    return args.fn(args)

if __name__ == "__main__":
    raise SystemExit(main())
